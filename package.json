    "cheerio": "^1.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "ollama": "^0.5.12",
    "pdfjs-dist": "^6.1.200",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "eslint": "^9.0.0"
  },
  "allowScripts": {
    "@whiskeysockets/baileys@6.7.23": true,
    "sharp@0.33.5": true,
    "bcrypt@5.1.1": true

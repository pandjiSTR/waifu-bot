# =============================================================================
# ARA DISCORD BOT — SAMPLE ENVIRONMENT VARIABLES (.env.example)
# Copy this file to ".env" and fill in real values before running the bot.
# Loaded at startup via: node --env-file .env
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_application_id
OWNER_DISCORD_ID=your_user_id
OLLAMA_API_KEY=your_ollama_api_key
REDIS_URL=rediss://default:password@host.upstash.io:6379
DASHBOARD_PASSWORD_HASH=your_bcrypt_hash
JWT_SECRET=your_random_hex

# ---------------------------------------------------------------------------
# OPTIONAL
# ---------------------------------------------------------------------------
COMMAND_PREFIX=!ara
GUILD_ID=
ALLOWED_CHANNEL_IDS=
ALLOWED_ROLE_IDS=
OWNER_NAME=Owner
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_TIMEOUT_MS=60000
LOG_LEVEL=warn
PORT=10000
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_MS=300000
CHUNK_SEND_RETRY=3
AUTO_CHAT_ENABLED=true
AUTO_CHAT_INTERVAL_MS=3600000
AUTO_CHAT_MIN_GAP_MS=10800000
ENABLE_CONTEXT_SUMMARY=false
MAX_CONTEXT_MESSAGES=30
MAX_GROUP_CONTEXT_MESSAGES=50
BLACKLIST=
WHITELIST=

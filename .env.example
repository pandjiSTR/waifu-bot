# =============================================================================
# ARA BOT — SAMPLE ENVIRONMENT VARIABLES (.env.example)
# Copy this file to ".env" and fill in real values before running the bot.
# This file contains ONLY placeholders — NO real secrets.
# Loaded at startup via: node --env-file .env
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED — must be set before the bot can start
# ---------------------------------------------------------------------------

# Ollama Cloud API key for the LLM provider
OLLAMA_API_KEY=your_ollama_api_key_here

# Ollama Cloud base URL (optional override). Defaults to the Ollama Cloud host.
# Set this only if your account is assigned a different base URL.
# Default: https://ollama.com
OLLAMA_HOST=https://ollama.com

# Enable context-window summarization (extra LLM calls to compress history).
# OFF by default; set to true to activate. Default: false
ENABLE_CONTEXT_SUMMARY=false

# Owner WhatsApp JID(s), comma-separated (e.g. 628xxxxxx@s.whatsapp.net or numeric id)
OWNER_NUMBER=628xxxxxx,123456789012345

# Bcrypt hash of the dashboard login password. Generate with bcrypt, never store plaintext.
# Example generation: `bcrypt.hashSync('your_password', 10)`
DASHBOARD_PASSWORD_HASH=bcrypt_hash_here

# Secret used to sign dashboard JWTs. Use a long random string.
# Generate with: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
JWT_SECRET=change_me_to_a_long_random_hex_string

# Upstash Redis connection URL (rediss:// for TLS)
REDIS_URL=rediss://default:password@host.upstash.io:6379

# ---------------------------------------------------------------------------
# OPTIONAL — has a default value; only set to override
# ---------------------------------------------------------------------------

# Display name of the owner (used by Ara to address the owner, ref {OWNER_NAME})
# Default: Owner
OWNER_NAME=Owner

# Comma-separated list of blocked numbers. Leave empty to allow everyone.
# Default: (empty)
BLACKLIST=

# Single model used for conversations + summarization
# Default: gemma4:31b-cloud
OLLAMA_MODEL=gemma4:31b-cloud

# LLM request timeout in milliseconds
# Default: 60000
OLLAMA_TIMEOUT_MS=60000

# Max messages per private chat context before summarization
# Default: 30
MAX_CONTEXT_MESSAGES=30

# Max messages per group chat context before summarization
# Default: 50
MAX_GROUP_CONTEXT_MESSAGES=50

# Group context TTL in Redis, in days (refreshed on each new message)
# Default: 7
GROUP_CTX_TTL_DAYS=7

# Seed for auto-chat toggle (proactive messaging) — only used on first start
# to initialize the Redis toggle. After that, the dashboard toggle controls it.
# Default: true
AUTO_CHAT_ENABLED=true

# Minimum gap between auto-chat messages in milliseconds (3 hours default)
# Default: 10800000 (3 hours)
AUTO_CHAT_MIN_GAP_MS=10800000

# Pino logging level: fatal, error, warn, info, debug, trace
# Default: warn
LOG_LEVEL=warn

# HTTP server port for the dashboard API and health check
# Default: 10000
PORT=10000

# Consecutive failures before the circuit breaker enters cooldown
# Default: 5
CIRCUIT_BREAKER_THRESHOLD=5

# Circuit breaker cooldown duration in milliseconds (5 minutes)
# Default: 300000
CIRCUIT_BREAKER_COOLDOWN_MS=300000

# Retry attempts per chunk when message sending fails
# Default: 3
CHUNK_SEND_RETRY=3

# Print QR code in terminal for WhatsApp Web pairing (vs waiting for link)
# Default: false
WA_PRINT_QR=false

# Comma-separated list of whitelisted JIDs (JIDs not in this list are rejected)
# When set, only these numbers can interact with the bot. Leave empty to allow all.
# Default: (empty — allow everyone)
WHITELIST=

# LLM retry base delay in milliseconds (exponential backoff)
# Default: 1000
OLLAMA_RETRY_BASE_MS=1000

# Base URL for web search API (Ollama Cloud web_search)
# Default: https://ollama.com
OLLAMA_WEB_BASE=https://ollama.com

# Interval between auto-chat cycles in milliseconds (1 hour default)
# Default: 3600000 (1 hour)
AUTO_CHAT_INTERVAL_MS=3600000

# Fallback message when circuit breaker is open (LLM unavailable)
# Default: lagi sibuk sebentar, coba lagi nanti
CIRCUIT_BREAKER_FALLBACK=lagi sibuk sebentar, coba lagi nanti
